{
	"name": "kr-dd-ranker",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"bd": "bun --bun run build",
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"dev": "vite dev",
		"fmt": "dprint fmt",
		"gen": "wrangler types",
		"lint": "eslint .",
		"prepare": "bunx --bun svelte-kit sync",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"test": "bun run test:unit -- --run",
		"test:unit": "vitest"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.0.18",
		"dprint": "^0.52.0",
		"eslint": "^9.39.2",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"playwright": "^1.58.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2",
		"wrangler": "^4.63.0"
	},
	"packageManager": "bun@1.3.10"
}
