{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "kr-dd-ranker",
	"compatibility_date": "2026-03-08",
	"compatibility_flags": [
		"nodejs_als",
	],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare",
	},
	"build": {
		"watch_dir": "./src",
		"command": "bun i && bun bd",
	},
	"vars": {
		"BUN_VERSION": "1.3.10",
		"SKIP_DEPENDENCY_INSTALL": "1",
	},
	"workers_dev": true,
	"preview_urls": true,
}
